# ═══════════════════════════════════════════════════════════════
# Atica Man — Environment Variables
# Copy to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Shopify Custom App ───────────────────────────────────────
SHOPIFY_STORE_URL=aticaman.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=            # From webhook settings

# ── External API Access ──────────────────────────────────────
ATICA_API_KEY=                     # openssl rand -hex 32

# ── Webhook Forwarding ───────────────────────────────────────
WEBHOOK_FORWARD_URL=               # e.g. https://your-app.com/webhooks
WEBHOOK_FORWARD_SECRET=            # Shared secret for verification

# ── Development ──────────────────────────────────────────────
SKIP_AUTH=true                     # Skip auth in local dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000
