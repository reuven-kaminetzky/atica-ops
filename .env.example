# ── Shopify Custom App ───────────────────────────────────────
# Get these from: Shopify Admin → Settings → Apps → Develop apps
SHOPIFY_STORE_URL=atica-man.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=            # Optional: from webhook settings

# ── External API Access ──────────────────────────────────────
# Any app outside Shopify can call your API using this key
# Generate a random key: openssl rand -hex 32
ATICA_API_KEY=

# ── Webhook Forwarding (optional) ────────────────────────────
# Set this to forward Shopify events to your external app
WEBHOOK_FORWARD_URL=               # e.g. https://your-app.com/webhooks
WEBHOOK_FORWARD_SECRET=            # Shared secret for your external app to verify

# ── Development ──────────────────────────────────────────────
SKIP_AUTH=true                     # Skip auth checks in local dev
